// test-execution
// Issue #1085 review, Finding 2: the slice source is evaluated exactly once.
// The unrolled writes previously inlined the source expression into every
// element, so an impure source (here a function that bumps a counter) ran once
// per element. Materializing the source into a single temp fixes that: all
// bytes come from one call, and the counter advances by exactly one.

u8 sliceSourceCallCount <- 0;

u32 nextSliceValue() {
    sliceSourceCallCount <- sliceSourceCallCount + 1;
    return 0x11223344;
}

u32 main() {
    u8[8] buffer;
    buffer[0, 4] <- nextSliceValue();

    // All four little-endian bytes must come from a single evaluation.
    if (buffer[0] != 0x44) return 1;
    if (buffer[1] != 0x33) return 2;
    if (buffer[2] != 0x22) return 3;
    if (buffer[3] != 0x11) return 4;

    // The source function must have run exactly once, not once per element.
    if (sliceSourceCallCount != 1) return 5;

    return 0;
}
