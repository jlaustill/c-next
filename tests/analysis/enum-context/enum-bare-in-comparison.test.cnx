// test-error
// Tests: Bare enum member in comparison should error (no expectedType)

enum EPressureType {
    PSIA <- 0,
    PSIG <- 1
}

scope EnumBareCompare {
    public struct Config {
    EPressureType pType;
}
}

u32 main() {
    EnumBareCompare.Config cfg <- {pType: EPressureType.PSIA};
    if (cfg.pType != PSIA) return 1;
    return 0;
}
