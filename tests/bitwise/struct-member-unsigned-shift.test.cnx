// test-execution
// Unsigned compound shift-assign on struct members should be allowed
// Verifies that the struct member resolution doesn't over-reject
struct Data {
    u8 value;
}

u32 main() {
    Data d <- {value: 1};
    d.value <<<- 2; // OK: u8 is unsigned
    if (d.value != 4) return 1;

    d.value <- 16;
    d.value >><- 2; // OK: u8 is unsigned
    if (d.value != 4) return 2;

    return 0;
}
