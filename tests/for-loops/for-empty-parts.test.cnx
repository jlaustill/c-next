// Coverage: Section 7.4 - for loop with empty init/condition/update
// Tests: for loops with optional parts omitted
u32 globalCounter <- 0;

// Test 1: Empty init (variable declared outside)
void testEmptyInit() {
    u32 i <- 0;
    for (; i < 5; i <- i + 1) {
        globalCounter +<- 1;
    }
}

// Test 2: Empty update (update inside loop body)
void testEmptyUpdate() {
    for (u32 i <- 0; i < 5; ) {
        globalCounter +<- 1;
        i <- i + 1;
    }
}

// Test 3: Empty init and update
void testEmptyInitAndUpdate() {
    u32 i <- 0;
    for (; i < 3; ) {
        globalCounter +<- 1;
        i <- i + 1;
    }
}

// Test 4: Use explicit condition instead of infinite loop + break
// C-Next doesn't have break; use structured conditions
void testExplicitCondition() {
    u32 count <- 0;
    for (u32 i <- 0; i < 5; i <- i + 1) {
        count +<- 1;
    }
    globalCounter +<- count;
}

// Test 5: All parts present (structured approach)
// C-Next doesn't have break; always use explicit loop conditions
void testStructuredLoop() {
    u32 i <- 0;
    for (; i < 3; ) {
        globalCounter +<- 1;
        i +<- 1;
    }
}

void main() {
    testEmptyInit();
    testEmptyUpdate();
    testEmptyInitAndUpdate();
    testExplicitCondition();
    testStructuredLoop();
}
