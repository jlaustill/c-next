// test-execution
// test-link: fake_lib.c
// Issue #995: Opaque-handle function parameters generate `const T*`,
// breaking calls to mutating C APIs.
//
// Bug: When widget_t (an opaque handle) is passed as a function parameter,
// the transpiler emits `const widget_t* w` instead of `widget_t* w`.
// This breaks calling C APIs like widget_move() that take non-const pointers.
#include "fake_lib.h"

scope UI {
    // Pass an opaque handle as a parameter, then hand it to a mutating C API.
    // The parameter MUST be `widget_t* w`, NOT `const widget_t* w`.
    private void reposition(widget_t w, i32 x) {
        global.widget_move(w, x);
    }

    public i32 run() {
        widget_t w <- global.widget_create();
        this.reposition(w, 42);
        i32 x <- global.widget_get_x(w);
        if (x != 42) return 1;
        return 0;
    }
}

i32 main() {
    return UI.run();
}
