// test-no-exec
// test-c-only
// Tests: cJSON array handling through ADR-061 C boundary layer
// Issue #931: Real-world library integration tests

#include "cjson_api.h"

void parseTelemetryArray() {
    string<64> payload <- "[10,20,30]";

    cJSON root <- global.cnext_cjson_parse(payload);
    i32 itemCount <- global.cnext_cjson_get_array_size(root);

    cJSON first <- global.cnext_cjson_get_array_item(root, 0);
    cJSON second <- global.cnext_cjson_get_array_item(root, 1);

    bool firstIsNumber <- global.cnext_cjson_is_number(first) != 0;
    f64 firstValue <- global.cnext_cjson_get_number_value(first);
    i32 secondValue <- global.cnext_cjson_get_valueint(second);

    global.cnext_cjson_delete(root);
}
