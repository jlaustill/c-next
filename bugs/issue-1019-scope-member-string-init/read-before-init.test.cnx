// test-error
// Issue #1019 Bug #1: Use-before-init for scope members should be caught
// Reading a scope-member string before initialization should produce E0381

scope S {
    string<16> buf;
    public u8 first() { return buf[0]; }   // ERROR: reads buf before it is ever written
}

u32 main() {
    u8 c <- S.first();
    return c;
}
