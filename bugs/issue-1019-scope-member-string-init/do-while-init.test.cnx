// test-execution
// Issue #1019 review feedback: do-while assignment should be detected
// A scope member assigned inside a do-while body should be readable elsewhere

scope S {
    string<16> buf;

    public void init() {
        u8 i <- 0;
        do {
            buf <- "initialized";
            i +<- 1;
        } while (i < 1);
    }

    public u8 len() {
        return buf.char_count;
    }
}

u32 main() {
    S.init();
    u8 length <- S.len();
    if (length != 11) return 1;  // "initialized" has 11 chars
    return 0;
}
