// test-c-only
// MISRA C:2012 Rule 17.7: the value returned by a non-void function shall be
// used or explicitly cast to (void). Issue #847.
#include <stdio.h>

scope Counter {
    u32 value <- 0;

    u32 next() {
        value <- value + 1;
        return value;
    }

    void reset() {
        value <- 0;
    }
}

i32 main() {
    // Non-void C-Next scope call, return discarded -> needs (void)
    Counter.next();

    // void C-Next scope call, no cast needed
    Counter.reset();

    // Non-void stdlib call, return discarded -> needs (void)
    printf("hello\n");

    // String assignment lowers to strncpy (returns char*) -> needs (void)
    string<16> name <- "ada";
    name <- "grace";

    return 0;
}
