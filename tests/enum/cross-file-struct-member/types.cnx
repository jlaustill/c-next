// Helper file: enum and struct definitions for cross-file struct member test

enum MyEnum {
    A <- 0,
    B <- 1,
    NONE <- 0xFF
}

scope CrossFileEnum {
    public struct TItem {
    MyEnum assigned;
    u8 padding;
}

    public struct Config {
    this.TItem items[4];
}
}

const u8 COUNT <- 4;

CrossFileEnum.Config config;
