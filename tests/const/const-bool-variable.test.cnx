// test-execution
// ADR-013: Const bool variable
// Tests: const bool declaration and read access

const bool FEATURE_ENABLED <- true;
const bool DEBUG_MODE <- false;

u32 main() {
   
// Test 1: Read true const into local variable
    bool enabled <- FEATURE_ENABLED;
    if (enabled = false) return 1;

   
// Test 2: Read false const
    bool debug <- DEBUG_MODE;
    if (debug = true) return 2;

   
// Test 3: Use const in conditional
    if (FEATURE_ENABLED = false) return 3;
    if (DEBUG_MODE = true) return 4;

   
// Test 4: Use const in logical expression
    bool result <- FEATURE_ENABLED && !DEBUG_MODE;
    if (result = false) return 5;

   
// Test 5: Use const in ternary
    u32 value <- (FEATURE_ENABLED = true) ? 100 : 0;
    if (value != 100) return 6;


// Test 6: Use false const in ternary
    u32 debugVal <- (DEBUG_MODE = true) ? 1 : 0;
    if (debugVal != 0) return 7;

    return 0;
}
