// test-error
// Test: Float division by literal zero should be rejected (E0800)
// Issue #1010: Float division by zero should error like integer division
// Previously expected infinity/NaN, now an error for parity with integers

f32 result_f32;
f64 result_f64;

void test_f32_division_by_zero() {
    f32 x <- 10.0;

    // Division by literal zero - should ERROR
    result_f32 <- x / 0.0;

    // Negative divided by zero
    f32 neg <- -10.0;
    result_f32 <- neg / 0.0;
}

void test_f64_division_by_zero() {
    f64 y <- 100.0;

    // Division by literal zero - should ERROR
    result_f64 <- y / 0.0;

    // Negative divided by zero
    f64 neg <- -100.0;
    result_f64 <- neg / 0.0;
}

void test_zero_divided_by_zero() {
    // 0.0 / 0.0 should also ERROR
    result_f32 <- 0.0 / 0.0;
    result_f64 <- 0.0 / 0.0;
}

void main() {
    test_f32_division_by_zero();
    test_f64_division_by_zero();
    test_zero_divided_by_zero();
}
