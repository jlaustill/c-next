// Issue #1052: a bit-range (and single-bit) write to a register field through a
// cross-scope `global.` path must expand to the mask/shift form, not emit a
// literal `[start, width]` subscript (which is invalid C).
scope Hw {
    public register GPIO @ 0x40020000 {
        Mode: u32 rw @ 0x00,
    }
}
scope App {
    public void configure() {
        global.Hw.GPIO.Mode[10, 2] <- 3;   // bit range
        global.Hw.GPIO.Mode[5] <- true;     // single bit
    }
}
